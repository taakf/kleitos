#!/bin/bash
# ============================================================================
# Axion by 4Labs — Plug & Play Launcher for macOS
#
# Double-click Axion.app. Everything sets itself up automatically.
# No terminal, no commands, no setup needed.
# ============================================================================

set -euo pipefail

APP_NAME="Axion"
PORT="${KLEITOS_PORT:-7777}"
HEALTH_URL="http://localhost:${PORT}/api/v1/health"
MAX_WAIT=45

# Resolve project directory:
# 1. Check ~/.axion-project-dir (written by installer)
# 2. Fall back to ~/.kleitos-project-dir (legacy)
# 3. Fall back to relative resolution from .app bundle
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if [[ -f "${HOME}/.axion-project-dir" ]]; then
    PROJECT_DIR="$(cat "${HOME}/.axion-project-dir")"
elif [[ -f "${HOME}/.kleitos-project-dir" ]]; then
    PROJECT_DIR="$(cat "${HOME}/.kleitos-project-dir")"
else
    PROJECT_DIR="$(cd "${SCRIPT_DIR}/../../.." && pwd)"
fi
VENV_DIR="${PROJECT_DIR}/.venv"

DATA_DIR="${HOME}/kleitos-data"
LOG_DIR="${DATA_DIR}/logs"
PYTHON="${VENV_DIR}/bin/python"

PLIST_NAME="com.axion.app"
PLIST_PATH="${HOME}/Library/LaunchAgents/${PLIST_NAME}.plist"

# Create data directories
mkdir -p "${DATA_DIR}/db"
mkdir -p "${DATA_DIR}/logs"
mkdir -p "${DATA_DIR}/backups"

LOG_FILE="${LOG_DIR}/launcher.log"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "${LOG_FILE}"
}

notify() {
    osascript -e "display notification \"$1\" with title \"${APP_NAME}\"" 2>/dev/null || true
}

alert() {
    osascript -e "display alert \"${APP_NAME}\" message \"$1\" as $2" 2>/dev/null || true
}

progress() {
    # Show a progress notification
    notify "$1"
}

# ============================================================================
# CHECK IF ALREADY RUNNING — just open dashboard
# ============================================================================
if curl -s -o /dev/null -w "%{http_code}" "${HEALTH_URL}" 2>/dev/null | grep -q "200"; then
    log "Already running — opening dashboard"
    open "http://localhost:${PORT}"
    exit 0
fi

# ============================================================================
# AUTO-SETUP: Install Python & Dependencies (first launch only)
# ============================================================================
if [[ ! -x "${PYTHON}" ]]; then
    log "First launch detected — setting up automatically..."
    progress "First launch — setting up (1-2 minutes)..."

    # --- Find or install Python ---
    SYS_PYTHON=""
    for candidate in python3.12 python3.11 python3; do
        if command -v "$candidate" &>/dev/null; then
            ver=$($candidate --version 2>&1 | grep -oE '[0-9]+\.[0-9]+')
            major=$(echo "$ver" | cut -d. -f1)
            minor=$(echo "$ver" | cut -d. -f2)
            if [[ "$major" -ge 3 && "$minor" -ge 11 ]]; then
                SYS_PYTHON="$candidate"
                break
            fi
        fi
    done

    # If no Python, try to install via Homebrew
    if [[ -z "$SYS_PYTHON" ]]; then
        log "Python 3.11+ not found — installing via Homebrew..."
        progress "Installing Python 3.12..."

        # Install Homebrew if missing
        if ! command -v brew &>/dev/null; then
            log "Installing Homebrew..."
            /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" </dev/null
            # Add to PATH for Apple Silicon
            if [[ -f /opt/homebrew/bin/brew ]]; then
                eval "$(/opt/homebrew/bin/brew shellenv)"
                export PATH="/opt/homebrew/bin:${PATH}"
            fi
        fi

        brew install python@3.12
        SYS_PYTHON="$(brew --prefix python@3.12)/bin/python3.12"

        if [[ ! -x "${SYS_PYTHON}" ]]; then
            SYS_PYTHON="python3.12"
        fi
    fi

    if [[ -z "$SYS_PYTHON" ]] || ! command -v "$SYS_PYTHON" &>/dev/null; then
        log "ERROR: Could not find or install Python 3.11+"
        alert "Could not find Python 3.11+.\n\nPlease install Python from python.org and try again." "critical"
        exit 1
    fi

    log "Using $($SYS_PYTHON --version)"

    # --- Create venv ---
    log "Creating virtual environment..."
    progress "Creating virtual environment..."
    $SYS_PYTHON -m venv "${VENV_DIR}"

    if [[ ! -x "${PYTHON}" ]]; then
        log "ERROR: venv creation failed"
        alert "Failed to create Python virtual environment." "critical"
        exit 1
    fi

    # --- Install dependencies ---
    log "Installing dependencies..."
    progress "Installing dependencies (1-2 minutes)..."
    "${PYTHON}" -m pip install --upgrade pip -q 2>/dev/null
    "${PYTHON}" -m pip install -r "${PROJECT_DIR}/requirements.txt" -q

    if [[ $? -ne 0 ]]; then
        log "ERROR: pip install failed"
        alert "Failed to install dependencies. Check your internet connection and try again." "critical"
        exit 1
    fi

    # --- Verify ---
    "${PYTHON}" -c "import fastapi, uvicorn, sqlalchemy, aiosqlite, apscheduler" 2>/dev/null
    if [[ $? -ne 0 ]]; then
        log "ERROR: Package verification failed"
        alert "Package verification failed. Try deleting .venv and launching again." "critical"
        exit 1
    fi

    log "Dependencies installed successfully"

    # --- Create .env if needed ---
    ENV_FILE="${PROJECT_DIR}/.env"
    if [[ ! -f "${ENV_FILE}" ]]; then
        cat > "${ENV_FILE}" <<'ENVEOF'
# Axion Environment Configuration
# -----------------------------------
# Anthropic API key (optional — works without it using rule-based fallbacks)
# ANTHROPIC_API_KEY=sk-ant-...

# NewsAPI key (optional — for news collection)
# NEWSAPI_KEY=...
ENVEOF
    fi

    progress "Setup complete! Starting Axion..."
    log "Auto-setup complete"
fi

# ============================================================================
# AUTO-SETUP: Auto-start on boot via launchd (one-time)
# ============================================================================
if [[ ! -f "${PLIST_PATH}" ]]; then
    log "Configuring auto-start on boot..."
    mkdir -p "${HOME}/Library/LaunchAgents"

    cat > "${PLIST_PATH}" <<PLISTEOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${PLIST_NAME}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${PYTHON}</string>
        <string>-m</string>
        <string>uvicorn</string>
        <string>src.main:app</string>
        <string>--host</string>
        <string>127.0.0.1</string>
        <string>--port</string>
        <string>${PORT}</string>
    </array>
    <key>WorkingDirectory</key>
    <string>${PROJECT_DIR}</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${DATA_DIR}/logs/kleitos-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>${DATA_DIR}/logs/kleitos-stderr.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>${VENV_DIR}/bin:/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
        <key>KLEITOS_DATA_DIR</key>
        <string>${DATA_DIR}</string>
        <key>KLEITOS_DB_PATH</key>
        <string>${DATA_DIR}/db/kleitos.db</string>
    </dict>
</dict>
</plist>
PLISTEOF

    launchctl load "${PLIST_PATH}" 2>/dev/null || true
    log "Auto-start configured"
fi

# ============================================================================
# AUTO-SETUP: Copy to /Applications (one-time)
# ============================================================================
APP_SRC="${PROJECT_DIR}/Axion.app"
APP_DST="/Applications/Axion.app"

if [[ -d "${APP_SRC}" && ! -d "${APP_DST}" ]]; then
    log "Installing to /Applications..."
    # Write project dir for future launches from /Applications
    echo "${PROJECT_DIR}" > "${HOME}/.kleitos-project-dir"
    cp -R "${APP_SRC}" "${APP_DST}" 2>/dev/null || true
    log "Installed to /Applications/Axion.app"
fi

# ============================================================================
# START SERVER
# ============================================================================
cd "${PROJECT_DIR}"
log "Starting Axion from ${PROJECT_DIR}..."
notify "Starting Axion..."

export KLEITOS_DATA_DIR="${DATA_DIR}"
export KLEITOS_DB_PATH="${DATA_DIR}/db/kleitos.db"
export PATH="${VENV_DIR}/bin:${PATH}"

# Start uvicorn in background
"${PYTHON}" -m uvicorn src.main:app \
    --host 127.0.0.1 \
    --port ${PORT} \
    >> "${LOG_DIR}/kleitos-stdout.log" \
    2>> "${LOG_DIR}/kleitos-stderr.log" &

SERVER_PID=$!
echo "${SERVER_PID}" > "${DATA_DIR}/kleitos.pid"
log "Server started (PID ${SERVER_PID})"

# ============================================================================
# WAIT FOR HEALTH
# ============================================================================
waited=0
while true; do
    if ! kill -0 "${SERVER_PID}" 2>/dev/null; then
        log "ERROR: Server process died"
        alert "The server failed to start.\n\nCheck logs at:\n~/kleitos-data/logs/" "critical"
        exit 1
    fi

    status=$(curl -s -o /dev/null -w "%{http_code}" "${HEALTH_URL}" 2>/dev/null || echo "000")
    if [[ "${status}" == "200" ]]; then
        log "Axion is healthy!"
        break
    fi
    sleep 1
    waited=$((waited + 1))
    if [[ $waited -ge $MAX_WAIT ]]; then
        log "ERROR: Startup timed out after ${MAX_WAIT}s"
        alert "Startup timed out.\n\nCheck logs at:\n~/kleitos-data/logs/" "critical"
        exit 1
    fi
done

# ============================================================================
# OPEN DASHBOARD — native window if pywebview available, browser fallback
# ============================================================================
notify "Axion is ready!"

# Try native app window via pywebview
"${PYTHON}" -c "import webview" 2>/dev/null
if [[ $? -eq 0 ]]; then
    log "Opening native app window via pywebview..."
    "${PYTHON}" "${PROJECT_DIR}/scripts/axion-app.pyw" --dev &
else
    log "pywebview not available — opening in browser"
    open "http://localhost:${PORT}"
fi

log "Dashboard opened"
