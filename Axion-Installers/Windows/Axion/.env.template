# Axion Environment Configuration
# Copy this file to ~/.axion.env
# chmod 600 ~/.axion.env (on macOS/Linux)
#
# Both AXION_* and KLEITOS_* variable names are supported.
# AXION_* takes precedence if both are set.

# ==============================================
# AI PROVIDER (optional — core features work without it)
# ==============================================

# Anthropic API Key (recommended for AI-powered analysis)
# ANTHROPIC_API_KEY=

# ==============================================
# SYSTEM CONFIGURATION (defaults are fine)
# ==============================================

# Server port (default: 7777)
# AXION_PORT=7777

# Log level (default: INFO)
# AXION_LOG_LEVEL=INFO

# Data directory (default: ~/axion-data, falls back to ~/kleitos-data)
# AXION_DATA_DIR=~/axion-data

# ==============================================
# OPTIONAL: Telegram Alerts
# ==============================================

# Get a bot token from @BotFather on Telegram, then get your chat ID
# AXION_TELEGRAM_TOKEN=
# AXION_TELEGRAM_CHAT_ID=

# ==============================================
# OPTIONAL: Email Notifications
# ==============================================

# AXION_SMTP_USER=
# AXION_SMTP_PASSWORD=
# AXION_SMTP_HOST=smtp.gmail.com
# AXION_EMAIL_FROM=
# AXION_EMAIL_TO=

# ==============================================
# SECURITY (for network-exposed deployments)
# ==============================================

# API key for authenticating external requests.
# Localhost requests are always allowed without a key.
# AXION_API_KEY=

# ==============================================
# BACKWARD COMPATIBILITY
# ==============================================
# All KLEITOS_* variable names still work (e.g. KLEITOS_PORT, KLEITOS_DATA_DIR).
# AXION_* is preferred for new installations.
