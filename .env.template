# Axion Environment Configuration
# Copy this file to .env in the project root, or to ~/.axion.env
# chmod 600 ~/.axion.env (on macOS/Linux)
# Variable names use the KLEITOS_ prefix for backward compatibility with existing installs.
# A future release will add AXION_ aliases.

# ==============================================
# REQUIRED
# ==============================================

# Anthropic API Key (for LLM-based analysis)
# Without this, the system runs using built-in rule-based analysis.
ANTHROPIC_API_KEY=

# ==============================================
# OPTIONAL: Source API Keys
# ==============================================

# NewsAPI.org (free tier: 100 requests/day)
# NEWSAPI_KEY=

# ==============================================
# SECURITY (recommended for production)
# ==============================================

# API key for authenticating external API requests.
# Localhost requests (127.0.0.1) are always allowed without a key.
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(32))"
# KLEITOS_API_KEY=

# ==============================================
# SYSTEM CONFIGURATION (defaults are fine)
# ==============================================

# Axion API — default binds to localhost only (safe).
# Set to 0.0.0.0 to allow LAN access (requires KLEITOS_API_KEY).
# KLEITOS_HOST=127.0.0.1
KLEITOS_PORT=7777
KLEITOS_LOG_LEVEL=INFO

# Data directory
KLEITOS_DATA_DIR=~/kleitos-data

# Database
KLEITOS_DB_PATH=~/kleitos-data/db/kleitos.db

# LLM Model (for analysis and classification)
# KLEITOS_LLM_MODEL=claude-sonnet-4-6

# ==============================================
# OPTIONAL: Telegram Bot
# ==============================================

# Get a token from @BotFather on Telegram
# KLEITOS_TELEGRAM_TOKEN=
# KLEITOS_TELEGRAM_CHAT_ID=

# ==============================================
# OPTIONAL: Email Notifications
# ==============================================

# KLEITOS_SMTP_USER=
# KLEITOS_SMTP_PASSWORD=
# KLEITOS_SMTP_HOST=smtp.gmail.com
# KLEITOS_EMAIL_FROM=
# KLEITOS_EMAIL_TO=
