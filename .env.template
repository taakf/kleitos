# Axion Environment Configuration
# Copy this file to ~/.axion.env
# chmod 600 ~/.axion.env (on macOS/Linux)
#
# Both AXION_* and KLEITOS_* variable names are supported.
# AXION_* takes precedence if both are set.

# ==============================================
# AI PROVIDER (optional — core features work without it)
# ==============================================
#
# Axion supports three AI providers. Pick one (or one primary + one
# backup) and set the matching env var. All three are equally optional —
# the dashboard, news collection, alerts, exposures, CSV import, and
# deterministic risk scoring all work with no key configured.
#
# Use AI keys to enable:
#   - narrative impact analysis on collected news
#   - the Assistant tab (conversational queries over your portfolio)
#   - daily digest narrative paragraphs
#   - AI vision extraction for scanned-PDF portfolio imports

# Anthropic (Claude). Keys look like sk-ant-…
# ANTHROPIC_API_KEY=

# OpenAI / ChatGPT. Keys look like sk-… or sk-proj-…
# OPENAI_API_KEY=

# Google Gemini. Keys look like AIza…
# GOOGLE_API_KEY=

# Primary provider to use when more than one key is configured.
# One of: anthropic, openai, gemini, none (default: anthropic).
# AXION_LLM_PROVIDER=

# Backup provider for automatic fallback on rate-limit / 5xx / auth
# errors. Same value set as AXION_LLM_PROVIDER. Leave blank for no
# fallback.
# AXION_LLM_BACKUP_PROVIDER=

# Override the default model (per-provider sensible defaults apply).
# Examples:
#   AXION_LLM_MODEL=claude-sonnet-4-6        # Anthropic
#   AXION_LLM_MODEL=gpt-4o-mini              # OpenAI (cost-conscious)
#   AXION_LLM_MODEL=gemini-2.0-flash         # Google
# AXION_LLM_MODEL=

# ==============================================
# OPTIONAL NEWS SOURCES (require user API keys)
# ==============================================
#
# The default RSS news sources (Federal Reserve, ECB, MarketWatch,
# Google News Business, WSJ, Seeking Alpha, Investing.com) all work
# without any key. The optional API-key sources below add coverage if
# you have credentials.
#
# Missing-key sources show as "Missing key" in Settings → Sources, never
# as an error. Set the key, restart Axion, and toggle the source on.

# NewsAPI.org (newsapi-general). Free tier ~100 requests/day,
# development-only use. https://newsapi.org/
# NEWSAPI_KEY=

# Finnhub.io (finnhub-news). Free tier with a generous rate limit.
# https://finnhub.io/
# FINNHUB_KEY=

# Subscription / paid sources (Bloomberg, FactSet, Refinitiv, S&P
# Capital IQ, etc.) are NOT included in this build. Adding them is
# tracked in docs/OAUTH_ROADMAP.md.

# ==============================================
# SYSTEM CONFIGURATION (defaults are fine)
# ==============================================

# Server port (default: 7777)
# AXION_PORT=7777

# Log level (default: INFO)
# AXION_LOG_LEVEL=INFO

# Data directory (default: ~/axion-data, falls back to ~/kleitos-data)
# AXION_DATA_DIR=~/axion-data

# ==============================================
# OPTIONAL: Telegram Alerts
# ==============================================

# Get a bot token from @BotFather on Telegram, then get your chat ID
# AXION_TELEGRAM_TOKEN=
# AXION_TELEGRAM_CHAT_ID=

# ==============================================
# OPTIONAL: Email Notifications
# ==============================================

# AXION_SMTP_USER=
# AXION_SMTP_PASSWORD=
# AXION_SMTP_HOST=smtp.gmail.com
# AXION_EMAIL_FROM=
# AXION_EMAIL_TO=

# ==============================================
# SECURITY (for network-exposed deployments)
# ==============================================

# API key for authenticating external requests.
# Localhost requests are always allowed without a key.
# AXION_API_KEY=

# ==============================================
# BACKWARD COMPATIBILITY
# ==============================================
# All KLEITOS_* variable names still work (e.g. KLEITOS_PORT, KLEITOS_DATA_DIR).
# AXION_* is preferred for new installations.
