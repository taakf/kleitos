#!/bin/bash
# ============================================================================
# Axion by 4Labs — Plug & Play Launcher for macOS
#
# Double-click Axion.app. Everything sets itself up automatically.
# No terminal, no commands, no setup needed.
#
# Runtime architecture:
#   ~/axion-data/             — stable runtime home (default; ~/kleitos-data
#                               is honoured as a back-compat fallback)
#   ~/axion-data/app/         — copy of source code (src/, dashboard/, scripts/)
#   ${VENV_DIR}/              — Python virtual environment
#   ~/axion-data/db/          — SQLite database
#   ${LOG_DIR}/      — log files
#   Contents/Resources/       — bundled requirements.txt (always readable)
# ============================================================================

# NOTE: We intentionally do NOT use `set -e` here. In a launcher script,
# silent exits are catastrophic. Every critical command has explicit error
# handling with logging and user-visible alerts.
set -uo pipefail

# ============================================================================
# PATH BOOTSTRAP — critical for Finder-launched apps
#
# When macOS launches a .app via Finder, PATH is minimal (/usr/bin:/bin).
# Homebrew, Python 3.12, etc. live in /opt/homebrew/bin (Apple Silicon)
# or /usr/local/bin (Intel). We must add these BEFORE any detection logic.
# ============================================================================
for _dir in /opt/homebrew/bin /opt/homebrew/sbin /usr/local/bin /usr/local/sbin; do
    [[ -d "$_dir" ]] && export PATH="$_dir:$PATH"
done
unset _dir

# Also try to pick up user's shell environment for anything else
if [[ -f "${HOME}/.zprofile" ]]; then
    source "${HOME}/.zprofile" 2>/dev/null || true
elif [[ -f "${HOME}/.bash_profile" ]]; then
    source "${HOME}/.bash_profile" 2>/dev/null || true
elif [[ -f "${HOME}/.profile" ]]; then
    source "${HOME}/.profile" 2>/dev/null || true
fi

APP_NAME="Axion"
# Port: AXION_PORT preferred, KLEITOS_PORT honoured for back-compat.
PORT="${AXION_PORT:-${KLEITOS_PORT:-7777}}"
HEALTH_URL="http://localhost:${PORT}/api/v1/health"
MAX_WAIT=45

# ============================================================================
# STABLE RUNTIME PATHS — always in user home dir (no Finder EPERM issues)
# Default is ~/axion-data; ~/kleitos-data is honoured for back-compat.
# Matches the resolution in scripts/run_local.sh so both launchers agree.
# ============================================================================
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BUNDLE_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
BUNDLE_RESOURCES="${BUNDLE_DIR}/Resources"

if [[ -n "${AXION_DATA_DIR:-}" ]]; then
    DATA_DIR="${AXION_DATA_DIR}"
elif [[ -n "${KLEITOS_DATA_DIR:-}" ]]; then
    DATA_DIR="${KLEITOS_DATA_DIR}"
elif [[ -d "${HOME}/kleitos-data" ]] && [[ ! -d "${HOME}/axion-data" ]]; then
    DATA_DIR="${HOME}/kleitos-data"
else
    DATA_DIR="${HOME}/axion-data"
fi

LOG_DIR="${DATA_DIR}/logs"
RUNTIME_DIR="${DATA_DIR}/app"
VENV_DIR="${DATA_DIR}/.venv"
PYTHON="${VENV_DIR}/bin/python"

PLIST_NAME="com.axion.app"
PLIST_PATH="${HOME}/Library/LaunchAgents/${PLIST_NAME}.plist"

# Find source repo — used to copy/refresh runtime files
# Check pointer file first, then try relative resolution from bundle
REPO_DIR=""
if [[ -f "${HOME}/.axion-project-dir" ]]; then
    _candidate="$(cat "${HOME}/.axion-project-dir")"
    [[ -f "${_candidate}/src/main.py" ]] && REPO_DIR="${_candidate}"
elif [[ -f "${HOME}/.kleitos-project-dir" ]]; then
    _candidate="$(cat "${HOME}/.kleitos-project-dir")"
    [[ -f "${_candidate}/src/main.py" ]] && REPO_DIR="${_candidate}"
fi
if [[ -z "$REPO_DIR" ]]; then
    # Try relative resolution from .app bundle location
    _candidate="$(cd "${SCRIPT_DIR}/../../.." 2>/dev/null && pwd)"
    [[ -f "${_candidate}/src/main.py" ]] && REPO_DIR="${_candidate}"
fi

# Create data directories
mkdir -p "${DATA_DIR}/db"
mkdir -p "${DATA_DIR}/logs"
mkdir -p "${DATA_DIR}/backups"
mkdir -p "${RUNTIME_DIR}"

LOG_FILE="${LOG_DIR}/launcher.log"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "${LOG_FILE}"
}

notify() {
    # Skip osascript notifications when called from native binary
    # (the native binary sends notifications via PyObjC after Python init)
    [[ "${AXION_BOOTSTRAP_ONLY:-}" == "1" ]] && return 0
    osascript -e "display notification \"$1\" with title \"${APP_NAME}\"" 2>/dev/null || true
}

alert() {
    osascript -e "display alert \"${APP_NAME}\" message \"$1\" as $2" 2>/dev/null || true
}

progress() {
    notify "$1"
}

die() {
    log "FATAL: $1"
    alert "$1" "critical"
    exit 1
}

# Trap unexpected exits so they are always logged
trap 'log "Launcher exited (code $?)"' EXIT

log "Launcher started"
log "  Bundle: ${BUNDLE_DIR}"
log "  Data dir: ${DATA_DIR}"
log "  Runtime dir: ${RUNTIME_DIR}"
log "  Venv dir: ${VENV_DIR}"
log "  Repo dir: ${REPO_DIR:-NOT FOUND}"

# Immediate user feedback — show a notification before any heavy work
notify "Starting Axion..."

# ============================================================================
# CHECK IF ALREADY RUNNING — just open dashboard
# ============================================================================
if curl -s -o /dev/null -w "%{http_code}" "${HEALTH_URL}" 2>/dev/null | grep -q "200"; then
    log "Already running — opening dashboard"
    open "http://localhost:${PORT}"
    exit 0
fi

# ============================================================================
# COPY/REFRESH RUNTIME FILES — from repo or bundle to ${DATA_DIR}/app/
# ============================================================================
if [[ -n "$REPO_DIR" && -f "${REPO_DIR}/src/main.py" ]]; then
    # Copy from repo (preferred — gets latest source)
    log "Syncing runtime files from repo: ${REPO_DIR}"
    # Use rsync for efficient incremental copy; fall back to cp
    if command -v rsync &>/dev/null; then
        rsync -a --delete "${REPO_DIR}/src/" "${RUNTIME_DIR}/src/" 2>> "${LOG_FILE}" || true
        rsync -a --delete "${REPO_DIR}/dashboard/" "${RUNTIME_DIR}/dashboard/" 2>> "${LOG_FILE}" || true
        [[ -d "${REPO_DIR}/scripts" ]] && rsync -a "${REPO_DIR}/scripts/" "${RUNTIME_DIR}/scripts/" 2>> "${LOG_FILE}" || true
    else
        cp -R "${REPO_DIR}/src" "${RUNTIME_DIR}/" 2>> "${LOG_FILE}" || true
        cp -R "${REPO_DIR}/dashboard" "${RUNTIME_DIR}/" 2>> "${LOG_FILE}" || true
        [[ -d "${REPO_DIR}/scripts" ]] && cp -R "${REPO_DIR}/scripts" "${RUNTIME_DIR}/" 2>> "${LOG_FILE}" || true
    fi
    # Copy .env if it exists in repo but not in runtime
    if [[ -f "${REPO_DIR}/.env" && ! -f "${RUNTIME_DIR}/.env" ]]; then
        cp "${REPO_DIR}/.env" "${RUNTIME_DIR}/.env" 2>> "${LOG_FILE}" || true
    fi
    log "Runtime files synced from repo"
elif [[ -f "${RUNTIME_DIR}/src/main.py" ]]; then
    # Runtime dir already has files from a previous launch
    log "Using existing runtime files at ${RUNTIME_DIR}"
else
    die "Cannot find Axion source code.\n\nExpected src/main.py in repo or runtime directory.\n\nPlease run the install script first."
fi

# Verify runtime dir has what we need
if [[ ! -f "${RUNTIME_DIR}/src/main.py" ]]; then
    die "Runtime directory is incomplete — src/main.py not found.\n\nTry re-launching or running the install script."
fi

# ============================================================================
# FIND REQUIREMENTS — from bundle (preferred) or runtime dir
# ============================================================================
REQUIREMENTS_FILE=""
if [[ -f "${BUNDLE_RESOURCES}/requirements.txt" ]]; then
    REQUIREMENTS_FILE="${BUNDLE_RESOURCES}/requirements.txt"
    log "Using bundled requirements.txt"
elif [[ -f "${RUNTIME_DIR}/requirements.txt" ]]; then
    REQUIREMENTS_FILE="${RUNTIME_DIR}/requirements.txt"
    log "Using runtime requirements.txt"
elif [[ -n "$REPO_DIR" && -f "${REPO_DIR}/requirements.txt" ]]; then
    # Copy to runtime dir first (may fail due to EPERM), then use runtime copy
    cp "${REPO_DIR}/requirements.txt" "${RUNTIME_DIR}/requirements.txt" 2>/dev/null || true
    if [[ -f "${RUNTIME_DIR}/requirements.txt" ]]; then
        REQUIREMENTS_FILE="${RUNTIME_DIR}/requirements.txt"
        log "Copied requirements.txt from repo to runtime dir"
    fi
fi

if [[ -z "$REQUIREMENTS_FILE" ]]; then
    die "Cannot find requirements.txt.\n\nNot in app bundle, runtime dir, or repo.\nPlease reinstall Axion."
fi

# ============================================================================
# VENV HEALTH CHECK — skip setup if venv is already healthy
# ============================================================================
NEEDS_SETUP=false

if [[ ! -x "${PYTHON}" ]]; then
    log "Venv python not found or not executable — setup needed"
    NEEDS_SETUP=true
else
    # Venv python exists — check if core packages are importable
    if "${PYTHON}" -c "import fastapi, uvicorn, sqlalchemy" 2>/dev/null; then
        log "Venv is healthy — skipping setup"
        NEEDS_SETUP=false
    else
        log "Venv python exists but core packages missing — setup needed"
        NEEDS_SETUP=true
    fi
fi

# ============================================================================
# AUTO-SETUP: Install Python & Dependencies (only if truly needed)
# ============================================================================
if [[ "$NEEDS_SETUP" == "true" ]]; then
    log "First launch detected — setting up automatically..."
    progress "First launch — setting up (1-2 minutes)..."

    # --- Find or install Python ---
    SYS_PYTHON=""
    for candidate in \
        python3.12 \
        python3.11 \
        /opt/homebrew/bin/python3.12 \
        /opt/homebrew/bin/python3.11 \
        /usr/local/bin/python3.12 \
        /usr/local/bin/python3.11 \
        python3 \
        /opt/homebrew/bin/python3 \
        /usr/local/bin/python3; do
        if [[ "$candidate" == /* ]]; then
            [[ -x "$candidate" ]] || continue
            RESOLVED="$candidate"
        else
            RESOLVED="$(command -v "$candidate" 2>/dev/null)" || continue
        fi
        ver=$("$RESOLVED" --version 2>&1 | grep -oE '[0-9]+\.[0-9]+' || echo "0.0")
        major=$(echo "$ver" | cut -d. -f1)
        minor=$(echo "$ver" | cut -d. -f2)
        if [[ "$major" -ge 3 && "$minor" -ge 11 ]]; then
            SYS_PYTHON="$RESOLVED"
            log "Found suitable Python: $SYS_PYTHON ($("$RESOLVED" --version 2>&1))"
            break
        fi
    done

    # If no Python, try to install via Homebrew
    if [[ -z "$SYS_PYTHON" ]]; then
        log "Python 3.11+ not found — installing via Homebrew..."
        progress "Installing Python 3.12..."

        BREW_CMD=""
        if [[ -x /opt/homebrew/bin/brew ]]; then
            BREW_CMD="/opt/homebrew/bin/brew"
        elif [[ -x /usr/local/bin/brew ]]; then
            BREW_CMD="/usr/local/bin/brew"
        elif command -v brew &>/dev/null; then
            BREW_CMD="$(command -v brew)"
        fi

        if [[ -z "$BREW_CMD" ]]; then
            log "Installing Homebrew..."
            if ! /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" </dev/null >> "${LOG_DIR}/homebrew-install.log" 2>&1; then
                die "Homebrew installation failed.\n\nCheck ${LOG_DIR}/homebrew-install.log"
            fi
            if [[ -x /opt/homebrew/bin/brew ]]; then
                BREW_CMD="/opt/homebrew/bin/brew"
                eval "$(/opt/homebrew/bin/brew shellenv)"
                export PATH="/opt/homebrew/bin:${PATH}"
            elif [[ -x /usr/local/bin/brew ]]; then
                BREW_CMD="/usr/local/bin/brew"
            fi
        fi

        if [[ -z "$BREW_CMD" ]]; then
            die "Could not find or install Homebrew.\n\nPlease install it manually from brew.sh and try again."
        fi

        log "Using Homebrew at: $BREW_CMD"
        if ! "$BREW_CMD" install python@3.12 >> "${LOG_DIR}/brew-python-install.log" 2>&1; then
            die "Failed to install Python 3.12 via Homebrew.\n\nCheck ${LOG_DIR}/brew-python-install.log"
        fi
        SYS_PYTHON="$("$BREW_CMD" --prefix python@3.12)/bin/python3.12"

        if [[ ! -x "${SYS_PYTHON}" ]]; then
            SYS_PYTHON="python3.12"
        fi
    fi

    if [[ -z "$SYS_PYTHON" ]] || ! [[ -x "$SYS_PYTHON" ]]; then
        die "Could not find Python 3.11+.\n\nPlease install Python from python.org and try again."
    fi

    log "Using $("$SYS_PYTHON" --version)"

    # --- Create venv in ${VENV_DIR} ---
    log "Creating virtual environment at ${VENV_DIR}..."
    progress "Creating virtual environment..."
    if ! "$SYS_PYTHON" -m venv "${VENV_DIR}" 2>> "${LOG_FILE}"; then
        die "Failed to create Python virtual environment."
    fi

    if [[ ! -x "${PYTHON}" ]]; then
        die "venv creation succeeded but python binary not found at ${PYTHON}"
    fi

    log "Venv created at ${VENV_DIR}"

    # --- Install dependencies from bundled requirements.txt ---
    log "Installing dependencies from ${REQUIREMENTS_FILE}..."
    log "  (logging to pip-install.log)"
    progress "Installing dependencies (1-2 minutes)..."

    if ! "${PYTHON}" -m pip install --upgrade pip >> "${LOG_DIR}/pip-install.log" 2>&1; then
        log "WARNING: pip upgrade failed (continuing with existing pip)"
    fi

    if ! "${PYTHON}" -m pip install -r "${REQUIREMENTS_FILE}" >> "${LOG_DIR}/pip-install.log" 2>&1; then
        log "ERROR: pip install -r requirements.txt failed"
        log "ERROR: Requirements file used: ${REQUIREMENTS_FILE}"
        log "ERROR: See ${LOG_DIR}/pip-install.log for details"
        die "Failed to install dependencies.\n\nCheck ${LOG_DIR}/pip-install.log"
    fi

    log "pip install completed"

    # --- Verify core packages ---
    log "Verifying core packages..."
    if ! "${PYTHON}" -c "import fastapi, uvicorn, sqlalchemy, aiosqlite, apscheduler" 2>> "${LOG_FILE}"; then
        log "ERROR: Core package import verification failed"
        die "Package verification failed.\n\nTry deleting ${VENV_DIR} and launching again."
    fi

    log "Dependencies installed and verified successfully"

    # --- Create .env if needed ---
    ENV_FILE="${RUNTIME_DIR}/.env"
    if [[ ! -f "${ENV_FILE}" ]]; then
        cat > "${ENV_FILE}" <<'ENVEOF'
# Axion Environment Configuration
# -----------------------------------
# Anthropic API key (optional — works without it using rule-based fallbacks)
# ANTHROPIC_API_KEY=sk-ant-...

# NewsAPI key (optional — for news collection)
# NEWSAPI_KEY=...
ENVEOF
    fi

    progress "Setup complete! Starting Axion..."
    log "Auto-setup complete"
fi

# ============================================================================
# AUTO-SETUP: Auto-start on boot via launchd (one-time)
# ============================================================================
if [[ ! -f "${PLIST_PATH}" ]]; then
    log "Configuring auto-start on boot..."
    mkdir -p "${HOME}/Library/LaunchAgents"

    cat > "${PLIST_PATH}" <<PLISTEOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${PLIST_NAME}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${PYTHON}</string>
        <string>-m</string>
        <string>uvicorn</string>
        <string>src.main:app</string>
        <string>--host</string>
        <string>127.0.0.1</string>
        <string>--port</string>
        <string>${PORT}</string>
    </array>
    <key>WorkingDirectory</key>
    <string>${RUNTIME_DIR}</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${DATA_DIR}/logs/axion-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>${DATA_DIR}/logs/axion-stderr.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>${VENV_DIR}/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>AXION_DATA_DIR</key>
        <string>${DATA_DIR}</string>
        <key>AXION_DB_PATH</key>
        <string>${DATA_DIR}/db/kleitos.db</string>
        <key>KLEITOS_DATA_DIR</key>
        <string>${DATA_DIR}</string>
        <key>KLEITOS_DB_PATH</key>
        <string>${DATA_DIR}/db/kleitos.db</string>
    </dict>
</dict>
</plist>
PLISTEOF

    launchctl load "${PLIST_PATH}" 2>/dev/null || true
    log "Auto-start configured"
fi

# ============================================================================
# START SERVER — from the stable runtime directory
# ============================================================================
cd "${RUNTIME_DIR}"
log "Starting Axion from ${RUNTIME_DIR}..."
notify "Starting Axion..."

export AXION_DATA_DIR="${DATA_DIR}"
export AXION_DB_PATH="${DATA_DIR}/db/kleitos.db"
export KLEITOS_DATA_DIR="${DATA_DIR}"
export KLEITOS_DB_PATH="${DATA_DIR}/db/kleitos.db"
export PATH="${VENV_DIR}/bin:${PATH}"

# ============================================================================
# PRE-FLIGHT MIGRATIONS (Phase 3 — data safety hardening)
#
# Run scripts/migrate.py before uvicorn so any newer-DB / corrupt-DB /
# backup-failure condition is surfaced as a clear macOS alert instead of
# uvicorn dying with a Python traceback in the background.
# Exit codes documented at the top of scripts/migrate.py.
# ============================================================================
"${PYTHON}" "${RUNTIME_DIR}/scripts/migrate.py" \
    >> "${LOG_DIR}/migrate-stdout.log" \
    2>> "${LOG_DIR}/migrate-stderr.log"
MIGRATE_RC=$?
case "${MIGRATE_RC}" in
    0)
        log "Migrations OK (database is at schema head)"
        ;;
    2)
        log "Migration pre-flight: database is newer than this app (rc=${MIGRATE_RC})"
        alert "Your Axion data was created by a newer version of Axion. Update Axion or restore a backup from ${DATA_DIR}/backups/. Details: ${LOG_DIR}/migrate-stdout.log" "critical"
        exit 2
        ;;
    3)
        log "Migration pre-flight: database is corrupt or unreadable (rc=${MIGRATE_RC})"
        alert "Axion could not open the database at ${DATA_DIR}/db/. Your data was NOT modified. Restore a backup from ${DATA_DIR}/backups/. Details: ${LOG_DIR}/migrate-stdout.log" "critical"
        exit 3
        ;;
    4)
        log "Migration pre-flight: pre-migration backup failed (rc=${MIGRATE_RC})"
        alert "Axion could not create a safety backup before upgrading the database. No schema changes were applied. Free disk space and retry. Details: ${LOG_DIR}/migrate-stdout.log" "critical"
        exit 4
        ;;
    *)
        log "Migration pre-flight failed (rc=${MIGRATE_RC})"
        alert "Axion could not start because the database migration failed. Details: ${LOG_DIR}/migrate-stderr.log" "critical"
        exit 1
        ;;
esac

# Start uvicorn in background
"${PYTHON}" -m uvicorn src.main:app \
    --host 127.0.0.1 \
    --port ${PORT} \
    >> "${LOG_DIR}/axion-stdout.log" \
    2>> "${LOG_DIR}/axion-stderr.log" &

SERVER_PID=$!
echo "${SERVER_PID}" > "${DATA_DIR}/axion.pid"
log "Server started (PID ${SERVER_PID})"

# ============================================================================
# WAIT FOR HEALTH
# ============================================================================
waited=0
while true; do
    if ! kill -0 "${SERVER_PID}" 2>/dev/null; then
        log "ERROR: Server process died"
        log "ERROR: Check ${LOG_DIR}/axion-stderr.log for details"
        alert "The server failed to start.\n\nCheck logs at:\n${LOG_DIR}/" "critical"
        exit 1
    fi

    status=$(curl -s -o /dev/null -w "%{http_code}" "${HEALTH_URL}" 2>/dev/null || echo "000")
    if [[ "${status}" == "200" ]]; then
        log "Axion is healthy!"
        break
    fi
    sleep 1
    waited=$((waited + 1))
    if [[ $waited -ge $MAX_WAIT ]]; then
        log "ERROR: Startup timed out after ${MAX_WAIT}s"
        alert "Startup timed out.\n\nCheck logs at:\n${LOG_DIR}/" "critical"
        exit 1
    fi
done

# ============================================================================
# BOOTSTRAP COMPLETE
#
# When called from the native Axion binary (AXION_BOOTSTRAP_ONLY=1),
# we exit here. The native binary handles the GUI.
# When called standalone (e.g., from terminal), open the browser.
# ============================================================================
if [[ "${AXION_BOOTSTRAP_ONLY:-}" == "1" ]]; then
    log "Bootstrap-only mode — returning to native binary"
    exit 0
fi

notify "Axion is ready!"
log "Opening dashboard in browser (standalone bootstrap mode)"
open "http://localhost:${PORT}"
log "Dashboard opened"
